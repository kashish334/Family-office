# ════════════════════════════════════════════════════════════════
#  Family Office – .gitignore
# ════════════════════════════════════════════════════════════════

# ── Secrets & environment ────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
env/
ENV/

# ── Testing & coverage ───────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
nosetests.xml
test-results/

# ── Node / Frontend ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
frontend/dist/
frontend/build/
frontend/.vite/

# ── Docker ───────────────────────────────────────────────────────
docker-compose.override.yml

# ── IDEs & editors ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Uploads ──────────────────────────────────────────────────────
backend/uploads/
uploads/

# ── Alembic ──────────────────────────────────────────────────────
backend/app/database/migrations/versions/*.py
!backend/app/database/migrations/versions/.gitkeep

# ── Reports & exports ────────────────────────────────────────────
*.pdf
*.xlsx
*.csv
reports/

# ── Misc ─────────────────────────────────────────────────────────
.cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
celerybeat-schedule
celerybeat.pid
