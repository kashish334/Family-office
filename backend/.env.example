# ─── Application ────────────────────────────────────────────────
APP_NAME="Family Office API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"        # development | staging | production
DEBUG=true
SECRET_KEY="change-me-to-a-very-long-random-string-in-production"
ALLOWED_ORIGINS="http://localhost:5173,https://your-frontend.vercel.app"

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/family_office"
DATABASE_URL_SYNC="postgresql://postgres:password@localhost:5432/family_office"

# ─── JWT ────────────────────────────────────────────────────────
JWT_SECRET_KEY="change-me-jwt-secret-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MAX_TOKENS=2048

# ─── Redis / Celery ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ─── File Storage (AWS S3 or local) ─────────────────────────────
STORAGE_BACKEND="local"          # local | s3
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,application/pdf"

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME="family-office-uploads"

# ─── Email ──────────────────────────────────────────────────────
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_FROM="noreply@family-office.com"
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT=587
MAIL_TLS=true

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
