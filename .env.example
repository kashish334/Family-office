# ════════════════════════════════════════════════════════════════
#  Family Office – Environment Variable Template
#  Copy to .env and fill in your values.
#  This file IS safe to commit. .env is NOT.
# ════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=info

# ── Secrets ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_SECRET_KEY=REPLACE_WITH_another_openssl_rand_hex_32

# ── Database ─────────────────────────────────────────────────────
POSTGRES_DB=family_office
POSTGRES_PASSWORD=postgres           # change in production
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=                      # set a strong password in production

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── File Storage ─────────────────────────────────────────────────
STORAGE_BACKEND=local               # local | s3

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=family-office-uploads

# ── Email ────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@family-office.com

# ── Nginx ────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Performance ──────────────────────────────────────────────────
CELERY_CONCURRENCY=4
UVICORN_WORKERS=4

# ── Optional tools ───────────────────────────────────────────────
PGADMIN_EMAIL=admin@family-office.com
PGADMIN_PASSWORD=pgadmin
FLOWER_USER=admin
FLOWER_PASSWORD=flower

# ── Monitoring (optional) ────────────────────────────────────────
SENTRY_DSN=
